@model DevArena.Entities.Problems

@{
    ViewData["Title"] = "Solve - " + Model.title;
}

<div class="container-fluid mt-4">
    <div class="row">

        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">@Model.title</h4>
                </div>
                <div class="card-body" style="overflow-y: auto; max-height: 75vh;">
                    <h5 class="text-info border-bottom pb-2">Description</h5>
                    <p class="mb-4" style="white-space: pre-wrap;">@Model.description</p>

                    <h5 class="text-info border-bottom pb-2">Input Format</h5>
                    <div class="bg-light p-3 rounded mb-4 font-monospace text-dark">
                        <pre class="mb-0">@Model.input_format</pre>
                    </div>

                    <h5 class="text-info border-bottom pb-2">Output Format</h5>
                    <div class="bg-light p-3 rounded mb-4 font-monospace text-dark">
                        <pre class="mb-0">@Model.output_format</pre>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-code-slash"></i> Code Editor</h5>
                </div>
                <div class="card-body p-0">
                    <form asp-controller="Problems" asp-action="SubmitCode" method="post" class="d-flex flex-column h-100 p-3">

                        <input type="hidden" name="problem_id" value="@Model.problem_id" />
                        <input type="hidden" name="contest_id" value="@Model.contest_id" />

                        <div class="mb-3" style="width: 250px;">
                            <label for="language" class="form-label fw-bold">Select Language:</label>
                            <select id="language" name="language" class="form-select bg-light">
                                <option value="C++">C++ (GCC 9.2.0)</option>
                                <option value="Java">Java (OpenJDK 13)</option>
                                <option value="Python">Python (3.8.1)</option>
                                <option value="C#">C# (.NET Core 3.1)</option>
                            </select>
                        </div>

                        <div class="flex-grow-1 mb-3">
                            <textarea name="sourceCode"
                                      class="form-control bg-dark text-light border-secondary"
                                      style="font-family: 'Courier New', Courier, monospace; height: 100%; min-height: 400px; resize: none;"
                                      placeholder="Write your code here..."
                                      spellcheck="false"
                                      required></textarea>
                        </div>

                        <div class="text-end mt-auto pt-2">
                            <a asp-action="ContestProblems" asp-route-contestId="@Model.contest_id" class="btn btn-outline-secondary me-2">Cancel</a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="bi bi-play-fill"></i> Submit Solution
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>