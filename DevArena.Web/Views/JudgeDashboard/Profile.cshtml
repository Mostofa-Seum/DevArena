@model DevArena.Web.Models.JudgeApi.JudgeProfileDto

@{
    ViewData["Title"] = "Judge Profile";
    Layout = "~/Views/Shared/_JudgeLayout.cshtml";
}

<div class="container mt-4">

    <a asp-controller="JudgeDashboard"
       asp-action="Index"
       class="btn btn-outline-secondary mb-3">
        &larr; Back to Dashboard
    </a>

    <h2>Judge Profile</h2>

    <p class="text-muted">
        This profile is based on your participant account.
    </p>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card shadow-sm mt-3">
        <div class="card-header bg-dark text-white">
            Profile Information
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Name</div>
                <div class="col-md-8">@Model.name</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Email</div>
                <div class="col-md-8">@Model.email</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Assigned Contest</div>
                <div class="col-md-8">@Model.contestTitle</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Promoted By Host</div>
                <div class="col-md-8">@Model.promotedByHostName</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Status</div>
                <div class="col-md-8">
                    @if (Model.isActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">Judge Since</div>
                <div class="col-md-8">@Model.createdAt.ToString("dd MMM yyyy, hh:mm tt")</div>
            </div>

        </div>
    </div>
</div>