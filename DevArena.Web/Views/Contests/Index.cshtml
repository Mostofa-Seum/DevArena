@model List<DevArena.Entities.Contests>

@Html.Partial("_Message")

<div class="row pt-4">
    <div class="col-6">
        <h2>Manage Contests</h2>
    </div>
    <div class="col-6 text-end">
        <a class="btn btn-primary" asp-action="Details" asp-controller="Contests" asp-route-id="-1">
            <i class="bi bi-plus-circle-fill"></i> &nbsp; Add New Contest
        </a>
    </div>
    <hr />
</div>
<div class="row pt-2">
    <div class="col-12">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Is Active</th>
                    <th class="text-center" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.title</td>
                            <td>@item.start_time.ToString("yyyy-MM-dd")</td>
                            <td>@item.end_time.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (item.is_active)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="w-75 btn-group" role="group">
                                    <a class="btn btn-primary mx-2" asp-action="Details" asp-controller="Contests" asp-route-id="@item.id">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a class="btn btn-danger mx-2" asp-action="Delete" asp-controller="Contests" asp-route-id="@item.id" onclick="return confirm('Are you sure you want to delete this contest?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No Contests available.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>