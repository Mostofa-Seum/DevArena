@model List<DevArena.Entities.Contests>

@{
    var registeredContests = ViewBag.RegisteredContests as List<int> ?? new List<int>();
}

<div>
    <h1>Contests</h1>
    <table class="table table-hover">
        <thead>
            <tr>
                <th scope="col">Name</th>
                <th scope="col">Start Date</th>
                <th scope="col">End Date</th>
                @if (User.IsInRole("Participant"))
                {
                    <th scope="col" class="text-center" style="width: 250px;">Action</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var contest in Model)
            {
                <tr>
                    <td>@contest.title</td>
                    <td>@contest.start_time.ToString("yyyy-MM-dd")</td>
                    <td>@contest.end_time.ToString("yyyy-MM-dd")</td>

                    @if (User.IsInRole("Participant"))
                    {
                        <td class="text-center">
                            <a class="btn btn-info btn-sm me-2" asp-controller="Problems" asp-action="ContestProblems" asp-route-contestId="@contest.id">
                                <i class="bi bi-list-task"></i> View Problems
                            </a>

                            @if (registeredContests.Contains(contest.id))
                            {
                                // If they already joined, show Leave button
                                <a class="btn btn-danger btn-sm" asp-controller="ContestRegistration" asp-action="LeaveContest" asp-route-id="@contest.id">
                                    <i class="bi bi-box-arrow-right"></i> Leave
                                </a>
                            }
                            else
                            {
                                // If they haven't joined, show Join button
                                <a class="btn btn-success btn-sm" asp-controller="ContestRegistration" asp-action="JoinContest" asp-route-id="@contest.id">
                                    <i class="bi bi-box-arrow-in-right"></i> Join
                                </a>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>