@model DevArena.Models.SignupModel

@{
    ViewData["Title"] = "Sign Up";
    ViewData["HideNavbar"] = true;
}

<div class="container mt-4">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
        &larr; Back to Home
    </a>
</div>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body p-5">

                    <form asp-controller="Auth" asp-action="Signup" method="post">
                        <fieldset>
                            <legend class="mb-4 text-center fs-2 fw-bold text-primary">Create an Account</legend>

                            <div>
                                <label asp-for="Name" class="form-label mt-4">Full Name</label>
                                <input asp-for="Name" class="form-control" placeholder="Enter your full name" required>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div>
                                <label asp-for="Email" class="form-label mt-4">Email address</label>
                                <input asp-for="Email" type="email" class="form-control" aria-describedby="emailHelp" placeholder="Enter email" required>
                                <small id="emailHelp" class="form-text text-muted">We'll never share your email with anyone else.</small>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div>
                                <label asp-for="Password" class="form-label mt-4">Password</label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="Password (Min 6 characters)" autocomplete="off" required>
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div>
                                <label asp-for="ConfirmPassword" class="form-label mt-4">Retype Password</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Retype Password" autocomplete="off" required>
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div>
                                <label asp-for="Role" class="form-label mt-4">Account Type</label>
                                <select asp-for="Role" class="form-select" required>
                                    <option value="">-- Select Role --</option>
                                    <option value="Participant">Participant</option>
                                    <option value="Host">Host</option>
                                </select>
                                <span asp-validation-for="Role" class="text-danger"></span>
                            </div>

                            <div class="mt-5 text-center">
                                <button type="submit" class="btn btn-primary w-100 fs-5 py-2">Sign Up</button>
                            </div>

                            <div class="mt-3 text-center">
                                <span class="text-muted">Already have an account? </span>
                                <a asp-controller="Auth" asp-action="Login" class="text-decoration-none">Log in here</a>
                            </div>

                        </fieldset>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}